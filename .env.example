# MongoDB — install locally or use Atlas. No Docker required.
MONGODB_URI=mongodb://127.0.0.1:27017/cargosignal
ALLOWED_ORIGINS=http://localhost:5173
NODE_ENV=development
PORT=3005

# Encrypts OAuth tokens at rest. Plain string or base64-32-byte key both work.
TOKEN_ENCRYPTION_KEY=
EMAIL_ENCRYPTION_KEY=

# Shared secret for Dat Go admin → Signal user sync (must match DATHUB SIGNAL_INTERNAL_API_KEY)
INTERNAL_API_KEY=

# FMCSA QCMobile API key — register free at https://mobile.fmcsa.dot.gov/qc
FMCSA_WEB_KEY=
FMCSA_WEBKEY=

# US proxy chain for FMCSA (required outside the US — copy from Loadline backend/.env)
HTTP_PROXY_HOST=
HTTP_PROXY_PORT=
HTTP_PROXY_USERNAME=
HTTP_PROXY_PASSWORD=
HTTP_PROXY_NAME=webshare-static-resi
HTTP_PROXY_BACKUP_HOST=
HTTP_PROXY_BACKUP_PORT=
HTTP_PROXY_BACKUP_USERNAME=
HTTP_PROXY_BACKUP_PASSWORD=
HTTP_PROXY_BACKUP_NAME=thordata-chicago
ALLOW_DIRECT_FETCH=false

# AI reply suggestions — OpenRouter (preferred) or Anthropic
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-20b:free
ANTHROPIC_API_KEY=

# Gmail OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3005/api/auth/gmail/callback
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:3005/api/auth/gmail/callback
GMAIL_PUBSUB_TOPIC=

# Outlook OAuth (optional)
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_REDIRECT_URI=http://localhost:3005/email/oauth/outlook/callback
MICROSOFT_GRAPH_WEBHOOK_URL=
